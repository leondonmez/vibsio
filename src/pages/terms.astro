---
/**
 * terms.astro — placeholder Terms of Service page.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { SITE } from '../data/network';
---

<BaseLayout
  title={`Terms of Service — ${SITE.name}`}
  description={`Terms of Service for ${SITE.legalName} and the vibs.io network of properties.`}
>
  <SiteHeader />
  <main class="mx-auto max-w-3xl px-6 py-24">
    <a href="/" class="text-sm text-indigo-400 transition hover:text-indigo-300">
      ← Back to studio
    </a>
    <h1 class="mt-6 text-4xl font-semibold tracking-tight text-white">
      Terms of Service
    </h1>
    <p class="mt-4 text-slate-400">
      This is a placeholder. Formal terms governing use of {SITE.legalName} and
      its network properties will be published here.
    </p>

    <div class="mt-10 space-y-6 text-sm leading-relaxed text-slate-400">
      <section>
        <h2 class="text-lg font-semibold text-white">1. Acceptance</h2>
        <p class="mt-2">
          By accessing any vibs.io property you agree to the terms that will be
          set out in this document.
        </p>
      </section>
      <section>
        <h2 class="text-lg font-semibold text-white">2. Use of services</h2>
        <p class="mt-2">
          Our tools are provided “as is” for lawful use. Detailed usage terms
          are forthcoming.
        </p>
      </section>
      <section>
        <h2 class="text-lg font-semibold text-white">3. Contact</h2>
        <p class="mt-2">
          Questions? Reach us at
          <a
            href="mailto:hello@vibs.io"
            class="text-indigo-400 transition hover:text-indigo-300"
          >hello@vibs.io</a>.
        </p>
      </section>
    </div>
  </main>
  <SiteFooter />
</BaseLayout>
