---
export const prerender = true;

import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import WorkspaceHeader from "../components/WorkspaceHeader.astro";
import WorkspaceSidebar from "../components/WorkspaceSidebar.astro";
import AuthGateModal from "../components/AuthGateModal.astro";
import VelocityGrid from "../components/VelocityGrid.astro";
import ForecastControls from "../components/ForecastControls.astro";
import BurnupChart from "../components/BurnupChart.astro";
import RequirementHub from "../components/RequirementHub.astro";
import GenerationTerminal from "../components/GenerationTerminal.astro";
import BlueprintGrid from "../components/BlueprintGrid.astro";
import IntegrationDrawer from "../components/IntegrationDrawer.astro";
import GovernancePanel from "../components/GovernancePanel.astro";
import ResourceOverlay from "../components/ResourceOverlay.astro";
import TokenManager from "../components/TokenManager.astro";
import OnboardingStep from "../components/OnboardingStep.astro";
import OutcomePreview from "../components/OutcomePreview.astro";
---

<BaseLayout>

  <!-- ======================= 5-PANE ENTERPRISE SHELL =======================
       AREA 3 top bar · AREA 1 sidebar · AREA 2 header · AREA 4 main pane ·
       AREA 5 context pane. 100vh lock on lg+, natural stacking on mobile. -->
  <div
    id="app-root"
    class="flex min-h-screen w-full flex-col bg-slate-50 lg:h-screen lg:w-screen lg:overflow-hidden dark:bg-slate-950"
  >
    <!-- AREA 3 -->
    <SiteHeader />

    <div id="app-columns" class="flex min-h-0 flex-1 flex-col lg:grid lg:grid-cols-[15rem_minmax(0,1fr)_minmax(0,40%)]">
      <!-- AREA 1 (last in mobile stacking order) -->
      <div class="order-3 min-h-0 lg:order-none lg:col-start-1 lg:row-start-1">
        <WorkspaceSidebar />
      </div>

      <!-- Central column: AREA 2 + AREA 4 -->
      <div class="order-1 flex min-h-0 min-w-0 flex-col lg:order-none lg:col-start-2 lg:row-start-1">
        <!-- AREA 2 -->
        <WorkspaceHeader />

        <!-- AREA 4 — main pane canvas (isolated internal scrolling) -->
        <main id="main" class="min-h-0 flex-1 p-3 lg:overflow-y-auto">
          <!-- VIEW 1 (default) — Scope & Requirements: the primary studio -->
          <div
            id="tab-panel-blueprint"
            role="tabpanel"
            aria-labelledby="tab-blueprint"
            class="flex flex-col gap-3"
          >
            <!-- Step 0: outcome preview for fresh workspaces -->
            <OutcomePreview />

            <!-- Project Objective: the first thing a PM sees on any blueprint -->
            <section
              aria-labelledby="objective-heading"
              class="rounded-xl border border-slate-200/60 bg-white p-3.5 shadow-sm sm:p-4 dark:border-slate-800 dark:bg-slate-900"
            >
              <h2 id="objective-heading" class="mb-2.5 text-sm font-medium tracking-tight text-slate-900 dark:text-slate-100">
                Project Objective
              </h2>
              <div class="flex flex-col gap-3">
                <div>
                  <label for="p-title" class="mb-1 block text-xs font-medium text-slate-600 dark:text-slate-400">
                    Project Title
                  </label>
                  <input
                    id="p-title"
                    data-bind="p.title"
                    type="text"
                    maxlength="200"
                    placeholder="What are we delivering?"
                    class="w-full rounded-lg border border-slate-300 bg-white px-2.5 py-1.5 text-sm dark:border-slate-700 dark:bg-slate-950"
                  />
                </div>
                <div>
                  <label for="p-objective" class="mb-1 block text-xs font-medium text-slate-600 dark:text-slate-400">
                    Business Goal &amp; Scope
                  </label>
                  <textarea
                    id="p-objective"
                    data-bind="p.objective"
                    rows="2"
                    maxlength="2000"
                    placeholder="What are we delivering and what makes it a win?"
                    class="w-full resize-y rounded-lg border border-slate-300 bg-white px-2.5 py-1.5 text-sm dark:border-slate-700 dark:bg-slate-950"
                  ></textarea>
                </div>
              </div>
            </section>

            <RequirementHub />
            <GenerationTerminal />
            <BlueprintGrid />

            <!-- Task Details (single-column flow, below the matrix) -->
            <section class="rounded-xl border border-slate-200/60 bg-white p-3.5 shadow-sm sm:p-4 dark:border-slate-800 dark:bg-slate-900">
              <h2 class="mb-1 text-sm font-medium tracking-tight text-slate-900 dark:text-slate-100">
                Task Details
              </h2>
              <p id="task-detail-empty" class="rounded-lg border border-dashed border-slate-300 px-4 py-6 text-center text-xs leading-relaxed text-slate-400 dark:border-slate-700 dark:text-slate-500">
                Select any task card in the Blueprint Matrix to inspect and
                polish its engineering breakdown here.
              </p>

              <div id="task-detail" class="hidden flex-col gap-3">
                <div class="flex items-center gap-2">
                  <span id="task-detail-tag" class="rounded-full px-2 py-0.5 text-[10px] font-semibold"></span>
                  <span id="task-detail-track" class="text-[10px] font-medium uppercase tracking-wide text-slate-400 dark:text-slate-500"></span>
                </div>
                <div>
                  <label for="task-detail-text" class="mb-1 block text-[11px] font-medium text-slate-500 dark:text-slate-400">
                    Subtask breakdown (title + acceptance criteria)
                  </label>
                  <textarea
                    id="task-detail-text"
                    rows="6"
                    maxlength="600"
                    class="w-full resize-y rounded-lg border border-slate-300 bg-white px-2.5 py-2 text-sm leading-relaxed dark:border-slate-700 dark:bg-slate-950"
                  ></textarea>
                </div>
                <div class="flex flex-wrap gap-2">
                  <button
                    id="task-copy-md"
                    type="button"
                    class="rounded-lg bg-indigo-600 px-3 py-1.5 text-xs font-semibold text-white shadow-sm transition hover:bg-indigo-500"
                  >
                    Copy task as Markdown
                  </button>
                  <button
                    id="task-detail-delete"
                    type="button"
                    class="rounded-lg border border-rose-200 px-3 py-1.5 text-xs font-medium text-rose-600 transition hover:bg-rose-50 dark:border-rose-900 dark:text-rose-400 dark:hover:bg-rose-950"
                  >
                    Delete task
                  </button>
                </div>
              </div>
            </section>

            <!-- Clipboard Packages -->
            <section class="rounded-xl border border-slate-200/60 bg-white p-3.5 shadow-sm sm:p-4 dark:border-slate-800 dark:bg-slate-900">
              <h2 class="mb-1 text-sm font-medium tracking-tight text-slate-900 dark:text-slate-100">
                Clipboard Packages
              </h2>
              <p class="mb-2.5 text-xs leading-relaxed text-slate-500 dark:text-slate-400">
                Compile the full task matrix into Universal Markdown or a
                structured JSON array for Jira, Linear, Asana, or Azure DevOps.
              </p>
              <button
                id="task-open-package"
                type="button"
                class="w-full rounded-lg border border-slate-300 px-3 py-2 text-xs font-semibold text-slate-700 transition hover:bg-slate-100 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800"
              >
                ⇪ Open Package Drawer
              </button>
            </section>
          </div>

          <!-- VIEW 2 — Quantitative Forecaster: history left, config right -->
          <div
            id="tab-panel-quant"
            role="tabpanel"
            aria-labelledby="tab-quant"
            class="hidden flex-col gap-3"
          >
            <div class="grid grid-cols-1 gap-3 lg:grid-cols-2 lg:items-start">
              <VelocityGrid />
              <ForecastControls />
            </div>
            <ResourceOverlay />
          </div>

          <!-- Backlog & Metadata -->
          <div
            id="tab-panel-admin"
            role="tabpanel"
            aria-labelledby="tab-admin"
            class="hidden flex-col gap-3"
          >
            <!-- Delivery metadata (title/objective live in Scope view) -->
            <section
              aria-labelledby="blueprint-heading"
              class="rounded-xl border border-slate-200/60 bg-white p-3.5 shadow-sm sm:p-4 dark:border-slate-800 dark:bg-slate-900"
            >
              <h2 id="blueprint-heading" class="mb-2.5 text-sm font-medium tracking-tight text-slate-900 dark:text-slate-100">
                Delivery Metadata
              </h2>
              <div class="grid gap-3 sm:grid-cols-2">
                <div>
                  <label for="p-start" class="mb-1 block text-xs font-medium text-slate-600 dark:text-slate-400">
                    <span data-term="cycle">Sprint</span> Start Date
                  </label>
                  <input
                    id="p-start"
                    data-bind="p.start"
                    type="date"
                    class="w-full rounded-lg border border-slate-300 bg-white px-2.5 py-1.5 text-sm dark:border-slate-700 dark:bg-slate-950"
                  />
                </div>
                <div>
                  <label for="p-owner" class="mb-1 block text-xs font-medium text-slate-600 dark:text-slate-400">
                    <span data-term="lead">Scrum Master</span>
                  </label>
                  <input
                    id="p-owner"
                    data-bind="p.owner"
                    type="text"
                    maxlength="120"
                    placeholder="Who keeps this on track?"
                    class="w-full rounded-lg border border-slate-300 bg-white px-2.5 py-1.5 text-sm dark:border-slate-700 dark:bg-slate-950"
                  />
                </div>
              </div>
            </section>

            <!-- Item board -->
            <section
              aria-labelledby="board-heading"
              class="rounded-xl border border-slate-200/60 bg-white p-3.5 shadow-sm sm:p-4 dark:border-slate-800 dark:bg-slate-900"
            >
              <div class="mb-1 flex items-baseline justify-between gap-3">
                <h2 id="board-heading" class="text-sm font-medium tracking-tight text-slate-900 dark:text-slate-100" data-term="board">
                  Sprint Board
                </h2>
                <span class="text-xs text-slate-400 dark:text-slate-500" data-term="backlog">Product Backlog</span>
              </div>
              <p class="mb-2.5 text-xs text-slate-500 dark:text-slate-400" data-term="boardHint">
                Capture user stories, point them, and pull them into the sprint.
              </p>

              <form id="item-form" class="mb-2.5 flex flex-col gap-2 sm:flex-row">
                <label for="item-title" class="sr-only">New item title</label>
                <input
                  id="item-title"
                  type="text"
                  maxlength="200"
                  data-term-ph="itemPlaceholder"
                  placeholder="e.g. As a user, I can share my board via link…"
                  class="min-w-0 flex-1 rounded-lg border border-slate-300 bg-white px-2.5 py-1.5 text-sm dark:border-slate-700 dark:bg-slate-950"
                />
                <label for="item-effort" class="sr-only">Effort estimate</label>
                <input
                  id="item-effort"
                  type="number"
                  min="0"
                  max="9999"
                  data-term-ph="effort"
                  placeholder="Story Points"
                  class="w-full rounded-lg border border-slate-300 bg-white px-2.5 py-1.5 text-sm sm:w-32 dark:border-slate-700 dark:bg-slate-950"
                />
                <button
                  type="submit"
                  class="rounded-lg bg-indigo-600 px-3.5 py-1.5 text-sm font-semibold text-white shadow-sm transition hover:bg-indigo-500"
                  data-term="addItem"
                >
                  Add User Story
                </button>
              </form>

              <ul id="item-list" class="flex flex-col gap-1.5" role="list"></ul>
              <p
                id="board-empty"
                class="rounded-lg border border-dashed border-slate-300 px-4 py-4 text-center text-sm text-slate-400 dark:border-slate-700 dark:text-slate-500"
              >
                Nothing here yet — add your first item above.
              </p>
            </section>
          </div>
        </main>
      </div>

      <!-- AREA 5 — persistent context details pane -->
      <aside
        id="context-pane"
        aria-label="Context details"
        class="order-2 min-h-0 border-slate-200/60 bg-white lg:order-none lg:col-start-3 lg:row-start-1 lg:h-full lg:overflow-y-auto lg:border-l dark:border-slate-800 dark:bg-slate-900/40"
      >
        <!-- Forecaster context: the Monte Carlo chart, pinned parallel to
             its data-input tables -->
        <div id="context-quant" class="hidden flex-col gap-3 p-3">
          <BurnupChart />
        </div>

        <!-- Backlog context: metrics + governance -->
        <div id="context-admin" class="hidden flex-col gap-3 p-3">
          <section aria-label="Workspace metrics" class="grid grid-cols-3 gap-3">
            <div class="rounded-lg border border-slate-200/60 bg-white p-3 shadow-sm dark:border-slate-800 dark:bg-slate-900">
              <p class="truncate text-xs font-medium text-slate-500 dark:text-slate-400" data-term="metricItems">
                Stories in Backlog
              </p>
              <p id="metric-items" class="mt-0.5 text-xl font-bold tracking-tight">0</p>
            </div>
            <div class="rounded-lg border border-slate-200/60 bg-white p-3 shadow-sm dark:border-slate-800 dark:bg-slate-900">
              <p class="truncate text-xs font-medium text-slate-500 dark:text-slate-400" data-term="metricEffort">
                Total Story Points
              </p>
              <p id="metric-effort" class="mt-0.5 text-xl font-bold tracking-tight">0</p>
            </div>
            <div class="rounded-lg border border-slate-200/60 bg-white p-3 shadow-sm dark:border-slate-800 dark:bg-slate-900">
              <p class="truncate text-xs font-medium text-slate-500 dark:text-slate-400" data-term="metricDone">
                Sprint Completion
              </p>
              <p id="metric-done" class="mt-0.5 text-xl font-bold tracking-tight">0%</p>
            </div>
          </section>

          <!-- Markdown packages + direct API export configurations -->
          <section class="rounded-xl border border-slate-200/60 bg-white p-3.5 shadow-sm dark:border-slate-800 dark:bg-slate-900">
            <h2 class="mb-1 text-sm font-medium tracking-tight text-slate-900 dark:text-slate-100">
              Packages &amp; Export
            </h2>
            <p class="mb-2.5 text-xs leading-relaxed text-slate-500 dark:text-slate-400">
              Compile the backlog into Universal Markdown / JSON arrays, or
              configure tokens and publish straight to a live board.
            </p>
            <div class="flex flex-col gap-2">
              <button
                id="admin-open-package"
                type="button"
                class="w-full rounded-lg border border-slate-300 px-3 py-2 text-xs font-semibold text-slate-700 transition hover:bg-slate-100 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800"
              >
                ⇪ Markdown / JSON Package Drawer
              </button>
              <button
                id="admin-open-publish"
                type="button"
                class="w-full rounded-lg border border-slate-300 px-3 py-2 text-xs font-semibold text-slate-700 transition hover:bg-slate-100 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800"
              >
                🚀 API Export & Token Configuration
              </button>
            </div>
          </section>

          <GovernancePanel />
        </div>
      </aside>
    </div>
  </div>

  <AuthGateModal />
  <IntegrationDrawer />
  <TokenManager />
  <OnboardingStep />

  <script>
    import "../scripts/app.js";
  </script>
</BaseLayout>
