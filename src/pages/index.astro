---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import WorkspaceSidebar from "../components/WorkspaceSidebar.astro";
import AuthGateModal from "../components/AuthGateModal.astro";
---

<BaseLayout>
  <SiteHeader />

  <div class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:py-8">
    <div class="flex flex-col gap-6 lg:grid lg:grid-cols-[280px_1fr] lg:items-start lg:gap-8">
      <WorkspaceSidebar />

      <main id="main" class="flex min-w-0 flex-col gap-6">
        <!-- Session identity -->
        <section
          aria-labelledby="session-heading"
          class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm sm:p-6 dark:border-slate-800 dark:bg-slate-900"
        >
          <h1 id="session-heading" class="sr-only">Current planning workspace</h1>
          <label
            for="session-name"
            class="mb-1.5 block text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400"
          >
            Workspace Name
          </label>
          <input
            id="session-name"
            type="text"
            maxlength="120"
            placeholder="Untitled Blueprint"
            class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-lg font-semibold text-slate-900 placeholder:text-slate-400 dark:border-slate-700 dark:bg-slate-950 dark:text-slate-100 dark:placeholder:text-slate-600"
          />
          <p class="mt-2 text-xs text-slate-500 dark:text-slate-400">
            Every change is compressed into the URL in real time — the address
            bar <em>is</em> your save file.
          </p>
        </section>

        <!-- Project blueprint fields -->
        <section
          aria-labelledby="blueprint-heading"
          class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm sm:p-6 dark:border-slate-800 dark:bg-slate-900"
        >
          <h2
            id="blueprint-heading"
            class="mb-4 text-sm font-semibold text-slate-900 dark:text-slate-100"
          >
            Project Blueprint
          </h2>
          <div class="grid gap-4 sm:grid-cols-2">
            <div class="sm:col-span-2">
              <label for="p-title" class="mb-1.5 block text-xs font-medium text-slate-600 dark:text-slate-400">
                Project Title
              </label>
              <input
                id="p-title"
                data-bind="p.title"
                type="text"
                maxlength="200"
                placeholder="What are we building?"
                class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm dark:border-slate-700 dark:bg-slate-950"
              />
            </div>
            <div class="sm:col-span-2">
              <label for="p-objective" class="mb-1.5 block text-xs font-medium text-slate-600 dark:text-slate-400">
                Objective
              </label>
              <textarea
                id="p-objective"
                data-bind="p.objective"
                rows="3"
                maxlength="2000"
                placeholder="The outcome that makes this project a win…"
                class="w-full resize-y rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm dark:border-slate-700 dark:bg-slate-950"
              ></textarea>
            </div>
            <div>
              <label for="p-start" class="mb-1.5 block text-xs font-medium text-slate-600 dark:text-slate-400">
                <span data-term="cycle">Sprint</span> Start Date
              </label>
              <input
                id="p-start"
                data-bind="p.start"
                type="date"
                class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm dark:border-slate-700 dark:bg-slate-950"
              />
            </div>
            <div>
              <label for="p-owner" class="mb-1.5 block text-xs font-medium text-slate-600 dark:text-slate-400">
                <span data-term="lead">Scrum Master</span>
              </label>
              <input
                id="p-owner"
                data-bind="p.owner"
                type="text"
                maxlength="120"
                placeholder="Who keeps this on track?"
                class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm dark:border-slate-700 dark:bg-slate-950"
              />
            </div>
          </div>
        </section>

        <!-- Metrics strip -->
        <section aria-label="Workspace metrics" class="grid grid-cols-1 gap-4 sm:grid-cols-3">
          <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-800 dark:bg-slate-900">
            <p class="text-xs font-medium text-slate-500 dark:text-slate-400" data-term="metricItems">
              Stories in Backlog
            </p>
            <p id="metric-items" class="mt-1 text-2xl font-bold tracking-tight">0</p>
          </div>
          <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-800 dark:bg-slate-900">
            <p class="text-xs font-medium text-slate-500 dark:text-slate-400" data-term="metricEffort">
              Total Story Points
            </p>
            <p id="metric-effort" class="mt-1 text-2xl font-bold tracking-tight">0</p>
          </div>
          <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-800 dark:bg-slate-900">
            <p class="text-xs font-medium text-slate-500 dark:text-slate-400" data-term="metricDone">
              Sprint Completion
            </p>
            <p id="metric-done" class="mt-1 text-2xl font-bold tracking-tight">0%</p>
          </div>
        </section>

        <!-- Item board -->
        <section
          aria-labelledby="board-heading"
          class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm sm:p-6 dark:border-slate-800 dark:bg-slate-900"
        >
          <div class="mb-1 flex items-baseline justify-between gap-3">
            <h2 id="board-heading" class="text-sm font-semibold text-slate-900 dark:text-slate-100" data-term="board">
              Sprint Board
            </h2>
            <span class="text-xs text-slate-400 dark:text-slate-500" data-term="backlog">Product Backlog</span>
          </div>
          <p class="mb-4 text-xs text-slate-500 dark:text-slate-400" data-term="boardHint">
            Capture user stories, point them, and pull them into the sprint.
          </p>

          <form id="item-form" class="mb-4 flex flex-col gap-2 sm:flex-row">
            <label for="item-title" class="sr-only">New item title</label>
            <input
              id="item-title"
              type="text"
              maxlength="200"
              required
              data-term-ph="itemPlaceholder"
              placeholder="e.g. As a user, I can share my board via link…"
              class="min-w-0 flex-1 rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm dark:border-slate-700 dark:bg-slate-950"
            />
            <label for="item-effort" class="sr-only">Effort estimate</label>
            <input
              id="item-effort"
              type="number"
              min="0"
              max="9999"
              data-term-ph="effort"
              placeholder="Story Points"
              class="w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm sm:w-36 dark:border-slate-700 dark:bg-slate-950"
            />
            <button
              type="submit"
              class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-indigo-500"
              data-term="addItem"
            >
              Add User Story
            </button>
          </form>

          <ul id="item-list" class="flex flex-col gap-2" role="list"></ul>
          <p
            id="board-empty"
            class="rounded-lg border border-dashed border-slate-300 px-4 py-8 text-center text-sm text-slate-400 dark:border-slate-700 dark:text-slate-500"
          >
            Nothing here yet — add your first item above.
          </p>
        </section>

        <!-- Protected AI module -->
        <section
          aria-labelledby="ai-heading"
          class="rounded-xl border border-indigo-200 bg-gradient-to-br from-indigo-50 to-white p-5 shadow-sm sm:p-6 dark:border-indigo-900 dark:from-indigo-950/40 dark:to-slate-900"
        >
          <div class="flex flex-col items-start justify-between gap-4 sm:flex-row sm:items-center">
            <div>
              <h2 id="ai-heading" class="flex items-center gap-2 text-sm font-semibold text-slate-900 dark:text-slate-100">
                <span aria-hidden="true">✨</span> AI Blueprint Assistant
              </h2>
              <p class="mt-1 text-xs leading-relaxed text-slate-600 dark:text-slate-400">
                Generate a full <span data-term="backlog">Product Backlog</span> from your objective —
                estimated, prioritized, and ready to plan. Requires sign-in.
              </p>
            </div>
            <button
              type="button"
              data-requires-auth
              class="shrink-0 rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-indigo-500"
            >
              Generate with AI
            </button>
          </div>
        </section>
      </main>
    </div>
  </div>

  <footer class="border-t border-slate-200 py-6 dark:border-slate-800">
    <p class="mx-auto max-w-7xl px-4 text-xs text-slate-400 sm:px-6 dark:text-slate-500">
      vibs.io — your plan lives in the URL. No account required for the local sandbox.
    </p>
  </footer>

  <AuthGateModal />

  <script>
    import "../scripts/app.js";
  </script>
</BaseLayout>
