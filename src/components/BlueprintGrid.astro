---
/**
 * LAYER 3 — Segmented task matrix: side-by-side split output grid.
 * Column 1: core engineering · Column 2: cross-functional extensions.
 * Cards render + inline-edit via blueprint.js; hidden until tasks exist.
 */
---

<section
  id="blueprint-grid-section"
  aria-labelledby="blueprint-grid-heading"
  class="hidden rounded-xl border border-slate-200 bg-white p-5 shadow-sm sm:p-6 dark:border-slate-800 dark:bg-slate-900"
>
  <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
    <h2 id="blueprint-grid-heading" class="text-sm font-semibold text-slate-900 dark:text-slate-100">
      Blueprint Task Matrix
    </h2>
    <div class="flex gap-2">
      <button
        id="open-drawer-btn"
        type="button"
        class="rounded-lg border border-slate-300 px-3 py-1.5 text-xs font-semibold text-slate-700 transition hover:bg-slate-100 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800"
      >
        ⇪ Integration Drawer
      </button>
      <button
        id="open-token-manager"
        type="button"
        class="rounded-lg border border-slate-300 px-3 py-1.5 text-xs font-semibold text-slate-700 transition hover:bg-slate-100 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800"
      >
        🚀 Publish to Board
      </button>
    </div>
  </div>
  <p class="mb-4 -mt-2 text-xs text-slate-500 dark:text-slate-400">
    Click <strong>Edit</strong> on any card to polish lines locally — no regeneration
    cycle needed, every keystroke stays synced to the URL.
  </p>

  <div class="grid gap-5 lg:grid-cols-2">
    <div>
      <div class="mb-3 flex items-center gap-2">
        <h3 class="text-xs font-semibold uppercase tracking-wide text-slate-600 dark:text-slate-300">
          Core Engineering Requirements
        </h3>
        <span
          id="core-count"
          class="rounded-full bg-indigo-50 px-2 py-0.5 text-[10px] font-bold text-indigo-700 dark:bg-indigo-950 dark:text-indigo-300"
          >0</span
        >
      </div>
      <ul id="core-task-list" class="flex flex-col gap-2.5" role="list"></ul>
    </div>

    <div>
      <div class="mb-3 flex items-center gap-2">
        <h3 class="text-xs font-semibold uppercase tracking-wide text-slate-600 dark:text-slate-300">
          Cross-Functional Extensions
        </h3>
        <span
          id="cross-count"
          class="rounded-full bg-indigo-50 px-2 py-0.5 text-[10px] font-bold text-indigo-700 dark:bg-indigo-950 dark:text-indigo-300"
          >0</span
        >
      </div>
      <ul id="cross-task-list" class="flex flex-col gap-2.5" role="list"></ul>
    </div>
  </div>
</section>
