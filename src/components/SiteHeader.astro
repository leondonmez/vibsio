---
/**
 * Global header — elite B2B commercial platform chrome.
 * Brand · Multi-Methodology Engine · workspace tier indicator dropdown ·
 * "Upgrade to Enterprise Pro" accent CTA · profile group · theme + tour.
 * Tier label + dropdown wiring live in app.js.
 */
---

<header
  class="z-40 shrink-0 border-b border-slate-200 bg-white/90 backdrop-blur dark:border-slate-800 dark:bg-slate-950/90"
>
  <div class="flex h-12 items-center gap-2 px-4 sm:gap-3 sm:px-5">
    <a href="/" class="flex items-center gap-2" aria-label="vibs.io home">
      <span
        class="flex h-6.5 w-6.5 items-center justify-center rounded-md bg-indigo-600 text-sm font-bold text-white"
        aria-hidden="true">v</span
      >
      <span class="text-sm font-semibold tracking-tight">vibs.io</span>
    </a>

    <div class="ml-auto flex items-center gap-1.5 sm:gap-2">
      <!-- Multi-Methodology Engine -->
      <label for="methodology-select" class="sr-only">Multi-Methodology Engine</label>
      <select
        id="methodology-select"
        class="h-8 rounded-md border border-slate-300 bg-white px-2 text-xs font-medium text-slate-700 shadow-sm dark:border-slate-700 dark:bg-slate-900 dark:text-slate-200"
        title="Multi-Methodology Engine — re-labels the whole workspace"
      >
        <option value="scrum">Scrum</option>
        <option value="kanban">Kanban</option>
        <option value="pmo">Traditional PMO</option>
      </select>

      <!-- Workspace tier status block (static) -->
      <div
        id="tier-status"
        class="hidden h-8 max-w-72 items-center gap-1.5 rounded-md border border-slate-300 bg-slate-50 px-2.5 text-xs font-medium text-slate-600 md:flex dark:border-slate-700 dark:bg-slate-900 dark:text-slate-300"
      >
        <span id="tier-dot" class="h-1.5 w-1.5 shrink-0 rounded-full bg-slate-400" aria-hidden="true"></span>
        <img id="tier-avatar" src="" alt="" referrerpolicy="no-referrer" class="hidden h-4 w-4 shrink-0 rounded-full" />
        <span id="tier-label" class="truncate">Workspace: Personal Sandbox (Free Tier)</span>
      </div>

      <!-- Profile group -->
      <button
        id="auth-signin-btn"
        type="button"
        class="h-8 rounded-md bg-indigo-600 px-3 text-xs font-semibold text-white shadow-sm transition hover:bg-indigo-500"
      >
        Sign in
      </button>
      <button
        id="auth-signout-btn"
        type="button"
        class="hidden h-8 rounded-md border border-slate-300 px-2.5 text-xs font-medium text-slate-600 transition hover:bg-slate-100 dark:border-slate-700 dark:text-slate-300 dark:hover:bg-slate-800"
      >
        Sign out
      </button>

      <!-- Theme toggle -->
      <button
        id="theme-toggle"
        data-theme-toggle
        type="button"
        aria-pressed="false"
        aria-label="Toggle dark mode"
        class="flex h-8 w-8 items-center justify-center rounded-md border border-slate-300 text-slate-600 transition hover:bg-slate-100 dark:border-slate-700 dark:text-slate-300 dark:hover:bg-slate-800"
      >
        <svg data-icon-moon class="hidden h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
        </svg>
        <svg data-icon-sun class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1.5m6.364.636l-1.06 1.06M21 12h-1.5m-.636 6.364l-1.06-1.06M12 19.5V21m-6.364-2.136l1.06-1.06M4.5 12H3m2.136-6.364l1.06 1.06M12 8.25a3.75 3.75 0 100 7.5 3.75 3.75 0 000-7.5z"></path>
        </svg>
      </button>

      <!-- Guided tour launcher -->
      <button
        id="tour-launch-btn"
        type="button"
        aria-label="Launch the guided tour"
        title="Guided tour"
        class="flex h-8 w-8 items-center justify-center rounded-md border border-slate-300 text-slate-600 transition hover:bg-slate-100 dark:border-slate-700 dark:text-slate-300 dark:hover:bg-slate-800"
      >
        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5.25h.008v.008H12v-.008z"
          ></path>
        </svg>
      </button>
    </div>
  </div>
</header>
