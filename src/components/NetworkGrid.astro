---
/**
 * NetworkGrid.astro — the portfolio. Renders one premium card per entry in
 * the NETWORK array. Live cards are wrapped in an anchor that opens the
 * property in a new tab; hover applies a subtle scale + border glow.
 */
import { NETWORK } from '../data/network';
---

<section id="network" class="relative border-b border-slate-900">
  <div class="mx-auto max-w-6xl px-6 py-24">
    <div class="max-w-2xl">
      <p class="text-sm font-semibold uppercase tracking-widest text-indigo-400">
        The Network
      </p>
      <h2 class="mt-3 text-3xl font-semibold tracking-tight text-white sm:text-4xl">
        Independent tools, one studio.
      </h2>
      <p class="mt-4 text-lg text-slate-400">
        Each property stands alone — its own domain, its own audience — while
        sharing our design system, infrastructure, and release velocity.
      </p>
    </div>

    <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        NETWORK.map((site) => (
          <a
            href={site.url}
            target="_blank"
            rel="noopener"
            class="group relative flex flex-col rounded-2xl border border-slate-800 bg-slate-900/40 p-6 transition duration-200 hover:-translate-y-1 hover:border-indigo-500/60 hover:bg-slate-900/70 hover:shadow-[0_0_40px_-8px_rgba(99,102,241,0.45)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-400"
          >
            <div class="flex items-start justify-between">
              <div
                class="flex h-12 w-12 items-center justify-center rounded-xl border border-slate-800 bg-slate-950/80 font-mono text-sm font-semibold text-indigo-300 transition group-hover:border-indigo-500/50 group-hover:text-violet-300"
                aria-hidden="true"
              >
                {site.glyph}
              </div>
              {/* Launch icon */}
              <span
                class="flex h-9 w-9 items-center justify-center rounded-lg border border-slate-800 text-slate-500 transition group-hover:border-indigo-500/50 group-hover:text-indigo-300"
                aria-hidden="true"
              >
                <svg
                  class="h-4 w-4 transition-transform duration-200 group-hover:-translate-y-0.5 group-hover:translate-x-0.5"
                  viewBox="0 0 20 20"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.7"
                >
                  <path
                    d="M7 13L13 7M13 7H8M13 7V12"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </span>
            </div>

            <h3 class="mt-6 text-xl font-semibold text-white">
              {site.name}
            </h3>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-slate-400">
              {site.description}
            </p>

            <div class="mt-6 flex items-center justify-between">
              <span class="rounded-full border border-slate-800 bg-slate-950/60 px-3 py-1 text-xs font-medium text-slate-400">
                {site.tag}
              </span>
              <span class="font-mono text-xs text-slate-500 transition group-hover:text-indigo-300">
                {site.url.replace('https://', '')}
              </span>
            </div>
          </a>
        ))
      }

      {/* Reserved slot — signals the fleet is growing (sites 4–10). */}
      <div
        class="flex flex-col items-center justify-center rounded-2xl border border-dashed border-slate-800/80 p-6 text-center"
      >
        <div
          class="flex h-12 w-12 items-center justify-center rounded-xl border border-slate-800 text-slate-600"
          aria-hidden="true"
        >
          <svg class="h-5 w-5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.7">
            <path d="M10 5v10M5 10h10" stroke-linecap="round" />
          </svg>
        </div>
        <p class="mt-4 text-sm font-medium text-slate-400">More in the lab</p>
        <p class="mt-1 text-xs text-slate-600">New utilities ship regularly.</p>
      </div>
    </div>
  </div>
</section>
