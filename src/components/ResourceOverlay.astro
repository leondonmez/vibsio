---
/**
 * LAYER 4 — Gated multi-team resource constraint overlay.
 * Controls bind into state.f (URL hash); the resulting "Constrained
 * Timeline" renders as a dashed vector on the Layer 2 burnup SVG.
 * Guests see a lock — organizational modeling is a signed-in feature.
 */
---

<section
  aria-labelledby="resource-overlay-heading"
  class="relative rounded-xl border border-slate-200 bg-white p-3.5 shadow-sm sm:p-4 dark:border-slate-800 dark:bg-slate-900"
>
  <div class="mb-1 flex flex-wrap items-center justify-between gap-2">
    <h2 id="resource-overlay-heading" class="text-sm font-semibold text-slate-900 dark:text-slate-100">
      Resource Constraint Overlay
    </h2>
    <span
      class="rounded-full bg-orange-50 px-2.5 py-0.5 text-[11px] font-semibold text-orange-600 dark:bg-orange-950 dark:text-orange-400"
      >Draws on the burnup chart</span
    >
  </div>
  <p class="mb-4 text-xs text-slate-500 dark:text-slate-400">
    Model macro-level organizational friction — the dashed Constrained
    Timeline projects what shrinking teams or cross-team dependencies do to
    the expected trajectory, before anyone touches live data.
  </p>

  <fieldset id="resource-controls" class="grid gap-4 sm:grid-cols-3">
    <legend class="sr-only">Resource modeling controls</legend>
    <div>
      <label for="fte-base" class="mb-1.5 block text-xs font-medium text-slate-600 dark:text-slate-400">
        Historical FTE Baseline
      </label>
      <input
        id="fte-base"
        type="number"
        min="1"
        max="500"
        class="w-full rounded-lg border border-slate-300 bg-white px-2.5 py-1.5 text-sm dark:border-slate-700 dark:bg-slate-950"
      />
      <p class="mt-1 text-[10px] text-slate-400 dark:text-slate-500">Team size that produced the velocity history</p>
    </div>
    <div>
      <label for="fte-count" class="mb-1.5 block text-xs font-medium text-slate-600 dark:text-slate-400">
        FTE Count Available
      </label>
      <input
        id="fte-count"
        type="number"
        min="1"
        max="500"
        class="w-full rounded-lg border border-slate-300 bg-white px-2.5 py-1.5 text-sm dark:border-slate-700 dark:bg-slate-950"
      />
      <p class="mt-1 text-[10px] text-slate-400 dark:text-slate-500">Full-time equivalents going forward</p>
    </div>
    <div>
      <div class="mb-1.5 flex items-center justify-between">
        <label for="friction-slider" class="text-xs font-medium text-slate-600 dark:text-slate-400">
          Dependency Friction Scale
        </label>
        <output
          id="friction-output"
          for="friction-slider"
          class="rounded-md bg-orange-50 px-2 py-0.5 text-xs font-semibold text-orange-600 dark:bg-orange-950 dark:text-orange-400"
          >1.00x</output
        >
      </div>
      <input
        id="friction-slider"
        type="range"
        min="1"
        max="2"
        step="0.05"
        value="1"
        aria-describedby="constrained-summary"
        class="w-full accent-orange-500"
      />
      <div class="mt-1 flex justify-between text-[10px] text-slate-400 dark:text-slate-500" aria-hidden="true">
        <span>1x smooth</span><span>1.5x</span><span>2x gridlock</span>
      </div>
    </div>
  </fieldset>

  <p id="constrained-summary" class="mt-3 text-xs font-medium text-slate-500 dark:text-slate-400" aria-live="polite">
    Overlay inactive — resources match the historical baseline.
  </p>

  <!-- Guest lock (STATE 1) -->
  <div
    id="resource-lock"
    class="absolute inset-0 hidden flex-col items-center justify-center gap-3 rounded-xl bg-white/70 backdrop-blur-sm dark:bg-slate-950/70"
  >
    <p class="max-w-xs px-4 text-center text-sm font-medium text-slate-700 dark:text-slate-300">
      🔒 Organizational modeling is a signed-in feature
    </p>
    <button
      id="resource-lock-signin"
      type="button"
      class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-indigo-500"
    >
      Unlock with sign-in
    </button>
  </div>
</section>
