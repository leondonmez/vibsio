---
/**
 * ENTRY OVERHAUL — one-click integrated demo engine.
 * The launch button injects a complete enterprise sample workspace through
 * the URL-hash pipeline (wired in app.js → src/utils/demoLoader.js).
 */
---

<div
  class="rounded-2xl border border-indigo-200 bg-white p-5 shadow-xl shadow-indigo-100/60 dark:border-indigo-900 dark:bg-slate-900 dark:shadow-none"
>
  <p class="text-xs font-semibold uppercase tracking-wide text-indigo-600 dark:text-indigo-400">
    See it working in one click
  </p>

  <!-- Decorative mini-burnup: a static hint of the live chart below -->
  <svg viewBox="0 0 300 110" class="mt-3 w-full" aria-hidden="true" fill="none">
    <line x1="10" y1="18" x2="290" y2="18" stroke="#a855f7" stroke-width="1.5" stroke-dasharray="5 4" opacity="0.7"></line>
    <polyline points="10,95 55,84 100,76 145,62 190,52" stroke="#6366f1" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"></polyline>
    <line x1="190" y1="52" x2="262" y2="18" stroke="#10b981" stroke-width="2" stroke-linecap="round"></line>
    <line x1="190" y1="52" x2="278" y2="18" stroke="#3b82f6" stroke-width="2" stroke-linecap="round"></line>
    <line x1="190" y1="52" x2="290" y2="24" stroke="#ef4444" stroke-width="2" stroke-linecap="round"></line>
    <circle cx="190" cy="52" r="3.5" fill="#6366f1"></circle>
  </svg>

  <button
    id="demo-launch-btn"
    type="button"
    class="mt-4 w-full rounded-xl bg-indigo-600 px-4 py-3.5 text-sm font-bold text-white shadow-lg shadow-indigo-600/25 transition hover:-translate-y-0.5 hover:bg-indigo-500 active:translate-y-0"
  >
    ⚡ Launch Live Interactive Playground
    <span class="block text-[11px] font-medium opacity-80">(With Sample Data)</span>
  </button>

  <button
    id="hero-tour-btn"
    type="button"
    class="mt-2 w-full rounded-xl border border-slate-300 px-4 py-2 text-xs font-semibold text-slate-600 transition hover:bg-slate-100 dark:border-slate-700 dark:text-slate-300 dark:hover:bg-slate-800"
  >
    Or take the 60-second guided tour
  </button>

  <p class="mt-3 text-center text-[11px] leading-relaxed text-slate-400 dark:text-slate-500">
    No login. Instantly reversible — hit <strong>New Blueprint</strong> to start clean.
  </p>
</div>
