---
/**
 * LAYER 2 — Real-time native SVG burnup renderer + executive exporter.
 * The <svg> is built element-by-element in forecast.js with literal colors,
 * so the export is a self-contained, transparent, presentation-ready vector.
 */
---

<section
  aria-labelledby="burnup-heading"
  class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm sm:p-6 dark:border-slate-800 dark:bg-slate-900"
>
  <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
    <div>
      <h2 id="burnup-heading" class="text-sm font-semibold text-slate-900 dark:text-slate-100">
        Delivery Forecast — Burnup
      </h2>
      <p class="mt-0.5 text-xs text-slate-500 dark:text-slate-400">
        Monte Carlo-backed trajectories · assumes 2-week
        <span data-term="cycle">Sprint</span>s for date estimates.
      </p>
    </div>
    <!-- Action drawer -->
    <div class="flex items-center gap-2">
      <button
        id="export-svg-btn"
        type="button"
        class="rounded-lg border border-slate-300 px-3 py-1.5 text-xs font-semibold text-slate-700 transition hover:bg-slate-100 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800"
      >
        ⬇ Export Report (.svg)
      </button>
    </div>
  </div>

  <!-- Scenario summary cards -->
  <div class="mb-5 grid grid-cols-1 gap-3 sm:grid-cols-3">
    <div
      id="scenario-optimistic"
      class="rounded-lg border border-emerald-200 bg-emerald-50/60 p-3 dark:border-emerald-900 dark:bg-emerald-950/40"
    >
      <p class="text-[11px] font-semibold uppercase tracking-wide text-emerald-700 dark:text-emerald-400">Optimistic</p>
      <p data-role="periods" class="mt-1 text-xl font-bold tracking-tight text-slate-900 dark:text-slate-100">—</p>
      <p data-role="velocity" class="text-xs text-slate-500 dark:text-slate-400">Awaiting data</p>
      <p data-role="eta" class="mt-0.5 text-[11px] text-slate-400 dark:text-slate-500"></p>
    </div>
    <div
      id="scenario-expected"
      class="rounded-lg border border-blue-200 bg-blue-50/60 p-3 dark:border-blue-900 dark:bg-blue-950/40"
    >
      <p class="text-[11px] font-semibold uppercase tracking-wide text-blue-700 dark:text-blue-400">Expected</p>
      <p data-role="periods" class="mt-1 text-xl font-bold tracking-tight text-slate-900 dark:text-slate-100">—</p>
      <p data-role="velocity" class="text-xs text-slate-500 dark:text-slate-400">Awaiting data</p>
      <p data-role="eta" class="mt-0.5 text-[11px] text-slate-400 dark:text-slate-500"></p>
    </div>
    <div
      id="scenario-pessimistic"
      class="rounded-lg border border-rose-200 bg-rose-50/60 p-3 dark:border-rose-900 dark:bg-rose-950/40"
    >
      <p class="text-[11px] font-semibold uppercase tracking-wide text-rose-700 dark:text-rose-400">Pessimistic</p>
      <p data-role="periods" class="mt-1 text-xl font-bold tracking-tight text-slate-900 dark:text-slate-100">—</p>
      <p data-role="velocity" class="text-xs text-slate-500 dark:text-slate-400">Awaiting data</p>
      <p data-role="eta" class="mt-0.5 text-[11px] text-slate-400 dark:text-slate-500"></p>
    </div>
  </div>

  <!-- Live SVG mount -->
  <div id="burnup-mount" class="min-h-24"></div>
  <p
    id="burnup-empty"
    class="rounded-lg border border-dashed border-slate-300 px-4 py-10 text-center text-sm text-slate-400 dark:border-slate-700 dark:text-slate-500"
  >
    The burnup renders here the moment you have velocity history <em>and</em> a remaining backlog.
  </p>
</section>
