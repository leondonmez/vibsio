---
/**
 * Zero-configuration sticky workspace sidebar. Lists local workspace history
 * from the localStorage index; entries carry rename / delete actions, plus a
 * "New Blueprint" reset. All rendering handled by app.js.
 */
---

<aside
  aria-label="Workspace history"
  class="lg:sticky lg:top-20 lg:h-max"
>
  <div
    class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm dark:border-slate-800 dark:bg-slate-900"
  >
    <div class="mb-3 flex items-center justify-between gap-2">
      <h2 class="text-sm font-semibold text-slate-900 dark:text-slate-100">Workspaces</h2>
      <span
        id="sync-status"
        class="text-[11px] font-medium text-emerald-600 opacity-0 transition-opacity dark:text-emerald-400"
        aria-hidden="true"></span>
    </div>

    <button
      id="new-blueprint-btn"
      type="button"
      class="mb-3 w-full rounded-lg border border-dashed border-indigo-300 px-3 py-2 text-sm font-medium text-indigo-600 transition hover:bg-indigo-50 dark:border-indigo-700 dark:text-indigo-400 dark:hover:bg-indigo-950"
    >
      + New Blueprint
    </button>

    <ul id="workspace-list" class="flex flex-col gap-1.5" role="list"></ul>

    <p class="mt-4 border-t border-slate-100 pt-3 text-[11px] leading-relaxed text-slate-400 dark:border-slate-800 dark:text-slate-500">
      Workspaces are stored locally in this browser. The full plan also lives
      in the URL — copy the address bar link to share or back up a blueprint.
    </p>
  </div>
</aside>
