---
/**
 * AREA 1 — Sidebar Navigation Hub (w-60, permanently dark for stark
 * enterprise contrast in both themes). Organizational nav groups on top,
 * the live workspace tree below. List rendering + nav wiring in app.js.
 */

const navItems = [
  { key: "home", icon: "🏠", label: "Home" },
  { key: "insights", icon: "📈", label: "Insights" },
  { key: "starred", icon: "⭐", label: "Starred Blueprints" },
  { key: "trees", icon: "🌲", label: "Project Trees" },
  { key: "channels", icon: "💬", label: "Team Channels", badge: "Pro" },
];
---

<aside
  aria-label="Navigation and workspaces"
  class="flex min-w-0 select-none flex-col border-slate-800 bg-slate-900 text-slate-300 lg:h-full lg:w-60 lg:shrink-0 lg:overflow-y-auto lg:border-r"
>
  <!-- Brand block -->
  <div class="flex items-center gap-2 px-4 pb-3 pt-4">
    <div>
      <p class="text-[13px] font-semibold tracking-tight text-white">Pre-Flight Sandbox</p>
      <p class="text-[10px] text-slate-500">Plan next to Jira &amp; Linear</p>
    </div>
  </div>

  <!-- Org navigation -->
  <nav aria-label="Sections" class="px-2">
    <ul class="flex flex-col gap-0.5" role="list">
      {
        navItems.map((item) => (
          <li>
            <button
              type="button"
              data-nav={item.key}
              class="flex w-full items-center gap-2.5 rounded-md px-2.5 py-1.5 text-left text-[13px] font-medium tracking-tight text-slate-300 transition hover:bg-white/5 hover:text-white"
            >
              <span aria-hidden="true" class="text-xs">{item.icon}</span>
              {item.label}
              {item.badge && (
                <span class="ml-auto rounded-full border border-indigo-400/40 px-1.5 py-px text-[9px] font-bold text-indigo-300">
                  {item.badge}
                </span>
              )}
            </button>
          </li>
        ))
      }
    </ul>
  </nav>

  <!-- Workspace tree -->
  <div id="workspace-tree" class="mt-4 flex-1 px-2">
    <div class="mb-1.5 flex items-center justify-between gap-2 px-2.5">
      <h2 class="text-[10px] font-bold uppercase tracking-widest text-slate-500">Project Trees</h2>
      <button
        id="new-blueprint-btn"
        type="button"
        aria-label="Start a new blueprint"
        title="New blueprint"
        class="flex h-5.5 w-5.5 items-center justify-center rounded border border-slate-700 text-xs font-bold text-indigo-300 transition hover:border-indigo-500 hover:bg-indigo-500/15 hover:text-indigo-200"
      >
        +
      </button>
    </div>
    <ul id="workspace-list" class="flex flex-col gap-0.5" role="list"></ul>
  </div>

  <!-- Footer -->
  <p class="border-t border-slate-800 px-4 py-3 text-[10px] leading-relaxed text-slate-500">
    Plans live in the URL — copy the address bar to share.
    <span class="mt-0.5 block">
      <a href="/privacy" class="hover:text-slate-300 hover:underline">Privacy</a>
      ·
      <a href="/terms" class="hover:text-slate-300 hover:underline">Terms</a>
    </span>
  </p>
</aside>
