---
/**
 * Slim workspace management rail. Dense, low-profile history list with
 * micro-typography; the "+" icon action spawns a fresh blueprint.
 * List rendering + actions handled by app.js.
 */
---

<aside
  aria-label="Workspace history"
  class="min-w-0 shrink-0 border-slate-200 px-4 pt-3 lg:h-full lg:w-56 lg:overflow-y-auto lg:border-r lg:bg-white/50 lg:px-3 lg:pb-3 dark:border-slate-800 lg:dark:bg-slate-900/30"
>
  <div class="mb-2 flex items-center justify-between gap-2">
    <h2 class="text-[11px] font-bold uppercase tracking-wide text-slate-500 dark:text-slate-400">
      Workspaces
    </h2>
    <div class="flex items-center gap-1.5">
      <span
        id="sync-status"
        class="text-[10px] font-medium text-emerald-600 opacity-0 transition-opacity dark:text-emerald-400"
        aria-hidden="true"></span>
      <button
        id="new-blueprint-btn"
        type="button"
        aria-label="Start a new blueprint"
        title="New blueprint"
        class="flex h-6 w-6 items-center justify-center rounded-md border border-slate-300 text-sm font-bold text-indigo-600 transition hover:border-indigo-400 hover:bg-indigo-50 dark:border-slate-700 dark:text-indigo-400 dark:hover:border-indigo-600 dark:hover:bg-indigo-950"
      >
        +
      </button>
    </div>
  </div>

  <ul id="workspace-list" class="flex flex-col gap-0.5" role="list"></ul>

  <p class="mt-3 border-t border-slate-200 pt-2 text-[10px] leading-relaxed text-slate-400 dark:border-slate-800 dark:text-slate-500">
    Stored locally. The full plan lives in the URL — copy the address bar to
    share or back up.
  </p>
</aside>
