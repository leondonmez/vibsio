---
/**
 * Hero.astro — studio identity headline, sub-copy, CTAs, and an animated
 * terminal-style visual. Pure markup + CSS animations (defined in
 * global.css) so there is zero client-side JS to ship.
 */
import { NETWORK } from '../data/network';

const liveCount = NETWORK.filter((s) => s.status === 'live').length;
---

<section class="relative overflow-hidden border-b border-slate-900">
  {/* Grid + ambient glow backdrop */}
  <div class="pointer-events-none absolute inset-0 vib-grid vib-grid-fade"></div>
  <div
    class="pointer-events-none absolute -top-32 left-1/2 h-72 w-72 -translate-x-1/2 rounded-full bg-indigo-600/25 vib-glow"
    aria-hidden="true"
  >
  </div>
  <div
    class="pointer-events-none absolute top-24 right-10 h-64 w-64 rounded-full bg-violet-600/20 vib-glow"
    aria-hidden="true"
  >
  </div>

  <div class="relative mx-auto max-w-6xl px-6 pt-28 pb-24 sm:pt-36 sm:pb-32">
    <div class="grid items-center gap-14 lg:grid-cols-[1.1fr_0.9fr]">
      {/* Copy column */}
      <div>
        <span
          class="inline-flex items-center gap-2 rounded-full border border-slate-800 bg-slate-900/60 px-3.5 py-1.5 text-xs font-medium tracking-wide text-slate-300"
        >
          <span class="relative flex h-2 w-2">
            <span
              class="absolute inline-flex h-full w-full animate-ping rounded-full bg-indigo-400/70"
            ></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-indigo-400"></span>
          </span>
          Digital venture studio · {liveCount} live properties
        </span>

        <h1
          class="mt-7 text-4xl font-semibold leading-[1.05] tracking-tight text-white sm:text-6xl"
        >
          We build atomic utilities
          <span
            class="bg-gradient-to-r from-indigo-400 via-violet-400 to-indigo-300 bg-clip-text text-transparent"
          >
            for the modern web.
          </span>
        </h1>

        <p class="mt-6 max-w-xl text-lg leading-relaxed text-slate-400">
          vibs.io is a micro-SaaS holding company shipping a network of
          hyper-focused, single-purpose tools. Sleek software, built at the
          speed of thought and scaled programmatically.
        </p>

        <div class="mt-9 flex flex-wrap items-center gap-4">
          <a
            href="#network"
            class="inline-flex items-center gap-2 rounded-lg bg-indigo-500 px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-indigo-500/25 transition hover:bg-indigo-400 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-400"
          >
            Explore the network
            <svg
              class="h-4 w-4"
              viewBox="0 0 20 20"
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              aria-hidden="true"
            >
              <path d="M4 10h12M11 5l5 5-5 5" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
          <a
            href="#philosophy"
            class="inline-flex items-center gap-2 rounded-lg border border-slate-800 bg-slate-900/40 px-5 py-3 text-sm font-semibold text-slate-200 transition hover:border-slate-700 hover:bg-slate-900"
          >
            Our thesis
          </a>
        </div>
      </div>

      {/* Animated terminal visual */}
      <div class="relative">
        <div
          class="overflow-hidden rounded-xl border border-slate-800 bg-slate-900/70 shadow-2xl shadow-black/40 backdrop-blur"
        >
          <div
            class="flex items-center gap-2 border-b border-slate-800 bg-slate-900/80 px-4 py-3"
          >
            <span class="h-3 w-3 rounded-full bg-red-400/80"></span>
            <span class="h-3 w-3 rounded-full bg-amber-400/80"></span>
            <span class="h-3 w-3 rounded-full bg-emerald-400/80"></span>
            <span class="ml-3 font-mono text-xs text-slate-500">vibsio — studio</span>
          </div>
          <div class="space-y-2.5 px-5 py-6 font-mono text-sm leading-relaxed">
            <p class="vib-line vib-line-1 text-slate-400">
              <span class="text-indigo-400">$</span> vibsio ship --idea "atomic tool"
            </p>
            <p class="vib-line vib-line-2 text-slate-500">
              <span class="text-violet-400">→</span> scaffolding edge-first static app
            </p>
            <p class="vib-line vib-line-3 text-slate-500">
              <span class="text-violet-400">→</span> deploying to global network
            </p>
            <p class="vib-line vib-line-4 text-emerald-400">
              ✓ live in production
              <span class="vib-cursor text-slate-300">▋</span>
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
