---
/**
 * CONTEXT HUB — permanent, low-profile brand/value banner.
 * A slim metadata strip between the header and the planning console that
 * keeps the product's purpose explicit on every tab, at a glance.
 * The demo + tour actions stay reachable from here.
 */
---

<section
  id="marketing-hero"
  aria-label="What vibs.io is"
  class="shrink-0 border-b border-slate-200 bg-gradient-to-r from-indigo-50 via-white to-white dark:border-slate-800 dark:from-indigo-950/40 dark:via-slate-950 dark:to-slate-950"
>
  <div class="flex flex-wrap items-center gap-x-3 gap-y-1.5 px-4 py-2 sm:px-5">
    <span class="inline-flex shrink-0 items-center gap-1.5 rounded-full border border-indigo-200 bg-white px-2.5 py-0.5 text-[11px] font-bold text-indigo-700 dark:border-indigo-800 dark:bg-slate-900 dark:text-indigo-300">
      <span aria-hidden="true">🧪</span> Pre-Flight Sandbox
    </span>

    <p class="min-w-0 flex-1 truncate text-xs text-slate-600 dark:text-slate-400">
      <strong class="font-semibold text-slate-800 dark:text-slate-200">The Pre-Flight Sandbox for High-Velocity Product Teams</strong>
      <span class="hidden sm:inline"> — a high-utility, framework-agnostic planning sandbox built next to Jira and Linear.</span>
    </p>

    <div class="flex shrink-0 items-center gap-1.5">
      <button
        id="demo-launch-btn"
        type="button"
        class="rounded-md bg-indigo-600 px-2.5 py-1 text-[11px] font-semibold text-white shadow-sm transition hover:bg-indigo-500"
      >
        ⚡ Load sample data
      </button>
      <button
        id="hero-tour-btn"
        type="button"
        class="rounded-md border border-slate-300 px-2.5 py-1 text-[11px] font-medium text-slate-600 transition hover:bg-slate-100 dark:border-slate-700 dark:text-slate-300 dark:hover:bg-slate-800"
      >
        Take the tour
      </button>
    </div>
  </div>
</section>
