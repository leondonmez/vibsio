---
/**
 * ENTRY OVERHAUL — strategic hero & market positioning sheet.
 * Sits directly below the header, above the live workspace. Fixes
 * "dashboard blindness": identity, positioning, and differentiators
 * before the user meets the grid.
 */
import QuickStartCard from "./QuickStartCard.astro";

const pillars = [
  {
    icon: "🔗",
    title: "100% Stateless Data",
    body: "Your whole plan is compressed into the URL itself — nothing stored on servers, share a link to share the plan.",
  },
  {
    icon: "🚀",
    title: "Zero Admin Overhead",
    body: "No configuration maps, no workspace setup, no accounts required. Open the page, start modeling.",
  },
  {
    icon: "🔄",
    title: "Framework Agnostic",
    body: "Instantly switches between Scrum, Kanban, and Traditional PMO definitions — every label, metric, and status.",
  },
];
---

<section
  id="marketing-hero"
  aria-labelledby="hero-heading"
  class="hidden shrink-0 overflow-y-auto border-b border-slate-200 bg-gradient-to-b from-indigo-50/70 via-white to-white dark:border-slate-800 dark:from-indigo-950/30 dark:via-slate-950 dark:to-slate-950"
>
  <div class="mx-auto grid max-w-7xl items-center gap-6 px-4 py-6 sm:px-6 lg:grid-cols-[minmax(0,1fr)_340px] lg:gap-10 lg:py-7">
    <div>
      <p class="mb-3 inline-flex items-center gap-1.5 rounded-full border border-indigo-200 bg-white px-3 py-1 text-[11px] font-semibold text-indigo-700 dark:border-indigo-800 dark:bg-slate-900 dark:text-indigo-300">
        <span aria-hidden="true">🧪</span> Test-drive the plan before the plan tests you
      </p>
      <h1
        id="hero-heading"
        class="text-3xl font-bold leading-tight tracking-tight text-slate-900 sm:text-4xl dark:text-slate-50"
      >
        The Pre-Flight Sandbox for
        <span class="text-indigo-600 dark:text-indigo-400">High-Velocity Product Teams.</span>
      </h1>
      <p class="mt-4 max-w-2xl text-sm leading-relaxed text-slate-600 sm:text-base dark:text-slate-400">
        A zero-login, stateless planning playground. Model Monte Carlo delivery forecasts, simulate
        organizational resource constraints, and decompose messy epics into stack-specific subtasks
        — without messing up your live Jira or Linear boards.
      </p>

      <!-- Differentiator matrix -->
      <dl class="mt-6 grid gap-3 sm:grid-cols-3">
        {
          pillars.map((pillar) => (
            <div class="rounded-xl border border-slate-200 bg-white/80 p-3.5 dark:border-slate-800 dark:bg-slate-900/60">
              <dt class="flex items-center gap-1.5 text-xs font-bold text-slate-900 dark:text-slate-100">
                <span aria-hidden="true">{pillar.icon}</span>
                {pillar.title}
              </dt>
              <dd class="mt-1 text-[11px] leading-relaxed text-slate-500 dark:text-slate-400">{pillar.body}</dd>
            </div>
          ))
        }
      </dl>
    </div>

    <QuickStartCard />
  </div>
</section>
