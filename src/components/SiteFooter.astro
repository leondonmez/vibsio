---
/**
 * SiteFooter.astro — global network footer. Ties the studio together with
 * the wordmark, a live index of the network, and legal links. The network
 * column is derived from the same NETWORK array as the portfolio grid.
 */
import { NETWORK, SITE } from '../data/network';

// Studio launch year — kept fixed so the legal line reads exactly as specified.
const year = 2026;
---

<footer class="relative">
  <div class="mx-auto max-w-6xl px-6 py-16">
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-[1.4fr_1fr_1fr]">
      {/* Brand */}
      <div>
        <a href="/" class="flex items-center gap-2.5" aria-label="vibs.io home">
          <span
            class="flex h-8 w-8 items-center justify-center rounded-lg bg-gradient-to-br from-indigo-500 to-violet-500 font-mono text-sm font-bold text-white"
            aria-hidden="true"
          >
            V
          </span>
          <span class="text-base font-semibold tracking-tight text-white">
            vibs.io
          </span>
        </a>
        <p class="mt-4 max-w-xs text-sm leading-relaxed text-slate-500">
          {SITE.tagline} Building atomic utilities and shipping them at the
          speed of thought.
        </p>
      </div>

      {/* Network index */}
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-widest text-slate-500">
          The Network
        </h3>
        <ul class="mt-4 space-y-3 text-sm">
          {
            NETWORK.map((site) => (
              <li>
                <a
                  href={site.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-slate-400 transition hover:text-indigo-300"
                >
                  {site.name}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      {/* Legal */}
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-widest text-slate-500">
          Studio
        </h3>
        <ul class="mt-4 space-y-3 text-sm">
          <li>
            <a href="/terms" class="text-slate-400 transition hover:text-indigo-300">
              Terms
            </a>
          </li>
          <li>
            <a href="/privacy" class="text-slate-400 transition hover:text-indigo-300">
              Privacy
            </a>
          </li>
          <li>
            <a
              href="mailto:hello@vibs.io"
              class="text-slate-400 transition hover:text-indigo-300"
            >
              Contact
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div
      class="mt-14 flex flex-col items-center justify-between gap-4 border-t border-slate-900 pt-8 sm:flex-row"
    >
      <p class="text-sm text-slate-500">
        © {year} {SITE.legalName}. All rights reserved.
      </p>
      <p class="font-mono text-xs text-slate-600">vibs.io</p>
    </div>
  </div>
</footer>
