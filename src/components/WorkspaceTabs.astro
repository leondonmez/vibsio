---
/**
 * LAYOUT CONSOLIDATION — centralized workspace tab navigator.
 * Low-profile horizontal tablist under the workspace title card; sticky
 * beneath the header so switching stays one click away at any depth.
 * Active/inactive states + switching logic live in src/scripts/tabs.js.
 */

const tabs = [
  { id: "quant", label: "Quantitative Sandbox", icon: "📊" },
  { id: "blueprint", label: "Requirement Blueprint Engine", icon: "✨" },
  { id: "admin", label: "Backlog & Metadata", icon: "📋" },
];
---

<nav aria-label="Workspace sections" class="sticky top-14 z-30 -mx-4 bg-slate-50/95 px-4 backdrop-blur sm:-mx-6 sm:px-6 dark:bg-slate-950/95">
  <div role="tablist" aria-label="Workspace panels" class="flex gap-1 overflow-x-auto border-b border-slate-200 dark:border-slate-800">
    {
      tabs.map((tab, i) => (
        <button
          type="button"
          role="tab"
          id={`tab-${tab.id}`}
          data-tab={tab.id}
          aria-selected={i === 0 ? "true" : "false"}
          aria-controls={`tab-panel-${tab.id}`}
          class="inline-flex items-center gap-1.5 whitespace-nowrap border-b-2 border-transparent px-3.5 py-2.5 text-sm font-semibold text-slate-500 transition-colors"
        >
          <span aria-hidden="true">{tab.icon}</span>
          {tab.label}
        </button>
      ))
    }
  </div>
</nav>
