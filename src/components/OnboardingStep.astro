---
/**
 * ONBOARDING LAYER — reusable spotlight + tooltip shell.
 * Four backdrop-blur mask panels surround a transparent "hole" that snaps
 * to each target element; the card glides between steps. All positioning,
 * content, and flow control live in src/scripts/onboarding.js.
 */
---

<div id="onboard-root" class="hidden" aria-hidden="true">
  <!-- 4-panel focus mask: everything OUTSIDE the spotlight hole is dimmed + blurred -->
  <div id="onboard-mask-top" class="fixed z-[60] bg-slate-950/40 backdrop-blur-sm transition-all duration-500"></div>
  <div id="onboard-mask-bottom" class="fixed z-[60] bg-slate-950/40 backdrop-blur-sm transition-all duration-500"></div>
  <div id="onboard-mask-left" class="fixed z-[60] bg-slate-950/40 backdrop-blur-sm transition-all duration-500"></div>
  <div id="onboard-mask-right" class="fixed z-[60] bg-slate-950/40 backdrop-blur-sm transition-all duration-500"></div>

  <!-- Spotlight ring around the highlighted element -->
  <div
    id="onboard-ring"
    class="pointer-events-none fixed z-[61] rounded-xl ring-2 ring-indigo-400 ring-offset-0 transition-all duration-500"
  ></div>
</div>

<!-- Step card (participates in tab order while the tour runs) -->
<div
  id="onboard-card"
  role="dialog"
  aria-modal="false"
  aria-labelledby="onboard-title"
  class="onboard-pop fixed z-[62] hidden w-[calc(100vw-2rem)] max-w-sm rounded-xl border border-slate-200 bg-white p-4 shadow-2xl transition-all duration-500 dark:border-slate-700 dark:bg-slate-900"
>
  <p id="onboard-step-label" class="text-[11px] font-semibold uppercase tracking-wide text-indigo-600 dark:text-indigo-400"></p>
  <h2 id="onboard-title" class="mt-1 text-base font-semibold text-slate-900 dark:text-slate-100"></h2>
  <p id="onboard-body" class="mt-1.5 text-sm leading-relaxed text-slate-600 dark:text-slate-400"></p>

  <button
    id="onboard-action"
    type="button"
    class="mt-3 hidden w-full rounded-lg bg-emerald-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-emerald-500"
  ></button>

  <div class="mt-4 flex items-center justify-between gap-2">
    <button
      id="onboard-back"
      type="button"
      class="rounded-lg px-3 py-1.5 text-xs font-medium text-slate-500 transition hover:bg-slate-100 dark:text-slate-400 dark:hover:bg-slate-800"
    >
      ← Back
    </button>
    <div class="flex items-center gap-1.5" id="onboard-dots" aria-hidden="true"></div>
    <button
      id="onboard-next"
      type="button"
      class="rounded-lg bg-indigo-600 px-4 py-1.5 text-xs font-semibold text-white shadow-sm transition hover:bg-indigo-500"
    >
      Next →
    </button>
  </div>
</div>

<!-- Floating tour badge: minimize / resume / dismiss forever -->
<div
  id="onboard-badge"
  class="fixed right-4 top-16 z-[63] hidden items-center gap-2 rounded-full border border-indigo-200 bg-white py-1.5 pl-3 pr-1.5 shadow-lg dark:border-indigo-800 dark:bg-slate-900"
>
  <span class="h-2 w-2 animate-pulse rounded-full bg-indigo-500" aria-hidden="true"></span>
  <span id="onboard-badge-label" class="text-xs font-semibold text-slate-700 dark:text-slate-200"></span>
  <button
    id="onboard-badge-toggle"
    type="button"
    class="rounded-full px-2 py-1 text-[11px] font-medium text-indigo-600 transition hover:bg-indigo-50 dark:text-indigo-400 dark:hover:bg-indigo-950"
  >
    Minimize
  </button>
  <button
    id="onboard-badge-dismiss"
    type="button"
    aria-label="Dismiss the tour forever"
    class="rounded-full p-1 text-slate-400 transition hover:bg-rose-50 hover:text-rose-600 dark:hover:bg-rose-950 dark:hover:text-rose-400"
  >
    <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
    </svg>
  </button>
</div>
