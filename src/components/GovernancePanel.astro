---
/**
 * LAYER 4 — Compliance governance, compacted to interactive selector chips.
 * Framework toggles live in state.g.frameworks (URL hash) and inject DoD
 * criteria into every generation. Wired by governance.js (same ids/inputs).
 */
import { COMPLIANCE_PROFILES } from "../utils/complianceProfiles.js";
const entries = Object.entries(COMPLIANCE_PROFILES);
---

<section
  aria-labelledby="governance-heading"
  class="rounded-xl border border-slate-200 bg-white p-3.5 shadow-sm sm:p-4 dark:border-slate-800 dark:bg-slate-900"
>
  <div class="mb-2 flex flex-wrap items-center justify-between gap-2">
    <div class="flex items-baseline gap-2">
      <h2 id="governance-heading" class="text-sm font-semibold text-slate-900 dark:text-slate-100">
        Governance &amp; Compliance
      </h2>
      <span class="hidden text-[10px] text-slate-400 sm:inline dark:text-slate-500">
        injected into every generated blueprint
      </span>
    </div>
    <span
      id="governance-count"
      class="rounded-full bg-slate-100 px-2 py-0.5 text-[10px] font-semibold text-slate-500 dark:bg-slate-800 dark:text-slate-400"
      >0 active</span
    >
  </div>

  <div class="flex flex-wrap gap-1.5">
    {
      entries.map(([key, profile]) => (
        <label class="cursor-pointer" for={`gov-${key}`} title={profile.summary}>
          <input type="checkbox" id={`gov-${key}`} data-framework={key} class="peer sr-only" />
          <span class="inline-flex items-center gap-1 rounded-full border border-slate-300 px-2.5 py-1 text-[11px] font-semibold text-slate-600 transition peer-checked:border-indigo-600 peer-checked:bg-indigo-600 peer-checked:text-white peer-focus-visible:outline peer-focus-visible:outline-2 peer-focus-visible:outline-indigo-500 hover:border-indigo-300 dark:border-slate-700 dark:text-slate-300 dark:peer-checked:border-indigo-500 dark:peer-checked:bg-indigo-600">
            {profile.label}
            <span class="text-[9px] font-normal opacity-70">{profile.dod.length} DoD</span>
          </span>
        </label>
      ))
    }
  </div>

  <details
    id="governance-dod"
    class="mt-2.5 hidden rounded-lg border border-slate-200 bg-slate-50 px-3 py-2 dark:border-slate-800 dark:bg-slate-950"
  >
    <summary class="cursor-pointer select-none text-[11px] font-semibold text-slate-500 dark:text-slate-400">
      Injected Definition of Done
    </summary>
    <ul id="governance-dod-list" class="mt-1.5 flex flex-col gap-1 text-[11px] text-slate-600 dark:text-slate-300" role="list"></ul>
  </details>
</section>
