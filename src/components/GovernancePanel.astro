---
/**
 * LAYER 4 — Compliance governance panel.
 * Framework toggles live in state.g.frameworks (URL hash) and inject
 * DoD criteria into every Layer 3 generation. Wired by governance.js.
 */
import { COMPLIANCE_PROFILES } from "../utils/complianceProfiles.js";
const entries = Object.entries(COMPLIANCE_PROFILES);
---

<section
  aria-labelledby="governance-heading"
  class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm sm:p-6 dark:border-slate-800 dark:bg-slate-900"
>
  <div class="mb-1 flex flex-wrap items-center justify-between gap-2">
    <h2 id="governance-heading" class="text-sm font-semibold text-slate-900 dark:text-slate-100">
      Governance &amp; Compliance Profiles
    </h2>
    <span
      id="governance-count"
      class="rounded-full bg-slate-100 px-2.5 py-0.5 text-[11px] font-semibold text-slate-500 dark:bg-slate-800 dark:text-slate-400"
      >0 active</span
    >
  </div>
  <p class="mb-4 text-xs text-slate-500 dark:text-slate-400">
    Active frameworks append Definition-of-Done criteria to the workspace and
    force every generated blueprint to include matching testing protocols.
  </p>

  <div class="grid gap-3 sm:grid-cols-2 xl:grid-cols-3">
    {
      entries.map(([key, profile]) => (
        <label
          class="flex cursor-pointer items-start gap-3 rounded-lg border border-slate-200 p-3 transition hover:border-indigo-300 has-checked:border-indigo-400 has-checked:bg-indigo-50/60 dark:border-slate-800 dark:hover:border-indigo-700 dark:has-checked:border-indigo-700 dark:has-checked:bg-indigo-950/40"
          for={`gov-${key}`}
        >
          <input
            type="checkbox"
            id={`gov-${key}`}
            data-framework={key}
            class="mt-0.5 h-4 w-4 shrink-0 accent-indigo-600"
          />
          <span class="min-w-0">
            <span class="block text-sm font-semibold text-slate-800 dark:text-slate-200">
              {profile.label}
            </span>
            <span class="mt-0.5 block text-[11px] leading-relaxed text-slate-500 dark:text-slate-400">
              {profile.summary}
            </span>
            <span class="mt-1 block text-[10px] font-medium uppercase tracking-wide text-indigo-500 dark:text-indigo-400">
              {profile.dod.length} DoD rules + 1 QA protocol
            </span>
          </span>
        </label>
      ))
    }
  </div>

  <div
    id="governance-dod"
    class="mt-4 hidden rounded-lg border border-slate-200 bg-slate-50 p-3 dark:border-slate-800 dark:bg-slate-950"
  >
    <p class="mb-2 text-[11px] font-semibold uppercase tracking-wide text-slate-500 dark:text-slate-400">
      Injected Definition of Done
    </p>
    <ul id="governance-dod-list" class="flex flex-col gap-1 text-xs text-slate-600 dark:text-slate-300" role="list"></ul>
  </div>
</section>
