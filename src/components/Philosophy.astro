---
/**
 * Philosophy.astro — the studio's operating thesis, rendered as a minimal
 * numbered text grid from the PHILOSOPHY constant.
 */
import { PHILOSOPHY } from '../data/network';
---

<section id="philosophy" class="relative border-b border-slate-900">
  <div class="mx-auto max-w-6xl px-6 py-24">
    <div class="max-w-2xl">
      <p class="text-sm font-semibold uppercase tracking-widest text-violet-400">
        Studio Philosophy
      </p>
      <h2 class="mt-3 text-3xl font-semibold tracking-tight text-white sm:text-4xl">
        How we operate.
      </h2>
      <p class="mt-4 text-lg text-slate-400">
        A repeatable playbook for launching profitable micro-utilities with
        minimal overhead and maximum focus.
      </p>
    </div>

    <div class="mt-14 grid gap-px overflow-hidden rounded-2xl border border-slate-900 bg-slate-900 sm:grid-cols-2">
      {
        PHILOSOPHY.map((item, i) => (
          <div class="group bg-slate-950 p-8 transition hover:bg-slate-900/60">
            <span class="font-mono text-sm text-indigo-400">
              {String(i + 1).padStart(2, '0')}
            </span>
            <h3 class="mt-4 text-lg font-semibold text-white">
              {item.title}
            </h3>
            <p class="mt-2 text-sm leading-relaxed text-slate-400">
              {item.body}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
