---
/**
 * LAYER 4 — Token manager + "Publish Directly to Project Board" drawer.
 * Credentials persist ONLY in browser localStorage (vibsio:integrations) —
 * a namespace the URL-hash state engine never touches. Wired by
 * integrations.js.
 */
---

<div id="token-backdrop" class="fixed inset-0 z-40 hidden bg-slate-950/40 backdrop-blur-sm"></div>

<aside
  id="token-manager"
  role="dialog"
  aria-modal="true"
  aria-labelledby="token-heading"
  aria-hidden="true"
  class="fixed inset-y-0 right-0 z-50 flex w-full max-w-md translate-x-full flex-col overflow-y-auto border-l border-slate-200 bg-white shadow-2xl transition-transform duration-300 dark:border-slate-800 dark:bg-slate-900"
>
  <div class="flex items-center justify-between border-b border-slate-200 px-5 py-4 dark:border-slate-800">
    <div>
      <h2 id="token-heading" class="text-sm font-semibold text-slate-900 dark:text-slate-100">
        Integrations &amp; Token Manager
      </h2>
      <p class="mt-0.5 text-xs text-slate-500 dark:text-slate-400">
        Publish the blueprint straight into a live board
      </p>
    </div>
    <button
      id="token-close"
      type="button"
      aria-label="Close token manager"
      class="rounded-md p-1.5 text-slate-400 transition hover:bg-slate-100 hover:text-slate-600 dark:hover:bg-slate-800 dark:hover:text-slate-300"
    >
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </div>

  <div class="flex flex-col gap-5 p-5">
    <p
      class="rounded-lg border border-amber-200 bg-amber-50 px-3 py-2.5 text-[11px] leading-relaxed text-amber-800 dark:border-amber-900 dark:bg-amber-950/50 dark:text-amber-300"
    >
      🔒 Tokens are stored only in this browser and sent only to the
      provider's own API. They are never written into your shareable URL and
      never transmitted to vibs.io servers.
    </p>

    <!-- Jira Cloud -->
    <fieldset class="rounded-lg border border-slate-200 p-4 dark:border-slate-800">
      <legend class="px-1 text-xs font-semibold text-slate-700 dark:text-slate-300">Jira Cloud</legend>
      <div class="flex flex-col gap-3">
        <div>
          <label for="jira-url" class="mb-1 block text-[11px] font-medium text-slate-500 dark:text-slate-400">Site URL</label>
          <input id="jira-url" type="url" placeholder="https://yourco.atlassian.net" autocomplete="off"
            class="w-full rounded-md border border-slate-300 bg-white px-2.5 py-1.5 text-sm dark:border-slate-700 dark:bg-slate-950" />
        </div>
        <div>
          <label for="jira-email" class="mb-1 block text-[11px] font-medium text-slate-500 dark:text-slate-400">Account Email</label>
          <input id="jira-email" type="email" placeholder="you@company.com" autocomplete="off"
            class="w-full rounded-md border border-slate-300 bg-white px-2.5 py-1.5 text-sm dark:border-slate-700 dark:bg-slate-950" />
        </div>
        <div>
          <label for="jira-token" class="mb-1 block text-[11px] font-medium text-slate-500 dark:text-slate-400">API Token</label>
          <input id="jira-token" type="password" placeholder="ATATT…" autocomplete="off"
            class="w-full rounded-md border border-slate-300 bg-white px-2.5 py-1.5 font-mono text-sm dark:border-slate-700 dark:bg-slate-950" />
        </div>
        <div>
          <label for="jira-project" class="mb-1 block text-[11px] font-medium text-slate-500 dark:text-slate-400">Project Key</label>
          <input id="jira-project" type="text" placeholder="ENG" maxlength="20" autocomplete="off"
            class="w-full rounded-md border border-slate-300 bg-white px-2.5 py-1.5 text-sm uppercase dark:border-slate-700 dark:bg-slate-950" />
        </div>
      </div>
    </fieldset>

    <!-- Linear -->
    <fieldset class="rounded-lg border border-slate-200 p-4 dark:border-slate-800">
      <legend class="px-1 text-xs font-semibold text-slate-700 dark:text-slate-300">Linear</legend>
      <div class="flex flex-col gap-3">
        <div>
          <label for="linear-key" class="mb-1 block text-[11px] font-medium text-slate-500 dark:text-slate-400">Personal API Key</label>
          <input id="linear-key" type="password" placeholder="lin_api_…" autocomplete="off"
            class="w-full rounded-md border border-slate-300 bg-white px-2.5 py-1.5 font-mono text-sm dark:border-slate-700 dark:bg-slate-950" />
        </div>
        <div>
          <label for="linear-team" class="mb-1 block text-[11px] font-medium text-slate-500 dark:text-slate-400">Team ID</label>
          <input id="linear-team" type="text" placeholder="a1b2c3d4-…" autocomplete="off"
            class="w-full rounded-md border border-slate-300 bg-white px-2.5 py-1.5 font-mono text-sm dark:border-slate-700 dark:bg-slate-950" />
        </div>
      </div>
    </fieldset>

    <div class="flex gap-2">
      <button id="token-save" type="button"
        class="flex-1 rounded-lg border border-slate-300 px-3 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-100 dark:border-slate-700 dark:text-slate-200 dark:hover:bg-slate-800">
        Save Tokens Locally
      </button>
      <button id="token-clear" type="button"
        class="rounded-lg border border-rose-200 px-3 py-2 text-sm font-medium text-rose-600 transition hover:bg-rose-50 dark:border-rose-900 dark:text-rose-400 dark:hover:bg-rose-950">
        Clear
      </button>
    </div>

    <!-- Publish -->
    <div class="border-t border-slate-200 pt-4 dark:border-slate-800">
      <label for="publish-target" class="mb-1.5 block text-xs font-medium text-slate-600 dark:text-slate-400">
        Destination Board
      </label>
      <select id="publish-target"
        class="mb-3 w-full rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm dark:border-slate-700 dark:bg-slate-950">
        <option value="jira">Jira Cloud</option>
        <option value="linear">Linear</option>
      </select>
      <button id="publish-btn" type="button"
        class="w-full rounded-lg bg-indigo-600 px-4 py-3 text-sm font-semibold text-white shadow-sm transition hover:bg-indigo-500">
        🚀 Publish Directly to Project Board
      </button>
      <div id="publish-results" class="mt-3 hidden rounded-lg border border-slate-200 bg-slate-50 p-3 text-xs leading-relaxed dark:border-slate-800 dark:bg-slate-950" aria-live="polite"></div>
    </div>
  </div>
</aside>
