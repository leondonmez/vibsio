---
/**
 * PUBLIC LANDING — premium marketing view for anonymous first visits.
 * Rendered by the view-splitter when there is no URL-hash data and no saved
 * history. The two CTAs hand off to the workspace (revealWorkspace /
 * demoLoader) via app.js. Fixed full-screen overlay; theme-aware.
 */
const features = [
  {
    icon: "🔗",
    title: "100% Stateless",
    body: "Your entire plan lives inside the URL hash — no servers, no database, no account. Copy the link to share the whole workspace, or bookmark it as a zero-risk backup. Delete the tab and nothing lingers.",
  },
  {
    icon: "🎚️",
    title: "The PM Spectrum",
    body: "One interface that speaks every dialect of delivery. Flip between Scrum, Kanban, and Traditional PMO and the math, metrics, and AI dictionary re-label themselves to match any shade of technical or non-technical workflow.",
  },
  {
    icon: "🛡️",
    title: "Enterprise Compliant",
    body: "A client-side PII filter scrubs keys, tokens, IPs, and emails before anything is processed, and built-in SOC 2 / ISO / HIPAA / GDPR / WCAG Definition-of-Done frameworks inject the right testing protocols automatically.",
  },
];
---

<div id="public-landing" class="fixed inset-0 z-50 overflow-y-auto bg-white dark:bg-slate-950">
  <!-- Minimal landing nav -->
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-5 sm:px-8">
    <span class="flex items-center gap-2">
      <span class="flex h-7 w-7 items-center justify-center rounded-lg bg-indigo-600 text-sm font-bold text-white" aria-hidden="true">v</span>
      <span class="text-base font-semibold tracking-tight text-slate-900 dark:text-slate-100">vibs.io</span>
    </span>
    <button
      id="landing-theme-toggle"
      data-theme-toggle
      type="button"
      aria-pressed="false"
      aria-label="Toggle dark mode"
      class="flex h-9 w-9 items-center justify-center rounded-lg border border-slate-300 text-slate-600 transition hover:bg-slate-100 dark:border-slate-700 dark:text-slate-300 dark:hover:bg-slate-800"
    >
      <svg data-icon-moon class="hidden h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"></path>
      </svg>
      <svg data-icon-sun class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1.5m6.364.636l-1.06 1.06M21 12h-1.5m-.636 6.364l-1.06-1.06M12 19.5V21m-6.364-2.136l1.06-1.06M4.5 12H3m2.136-6.364l1.06 1.06M12 8.25a3.75 3.75 0 100 7.5 3.75 3.75 0 000-7.5z"></path>
      </svg>
    </button>
  </nav>

  <!-- Hero -->
  <header class="mx-auto max-w-3xl px-6 pb-14 pt-14 text-center sm:pt-24">
    <span class="inline-flex items-center gap-1.5 rounded-full border border-indigo-200 bg-indigo-50 px-3.5 py-1 text-xs font-semibold text-indigo-700 dark:border-indigo-800 dark:bg-indigo-950/60 dark:text-indigo-300">
      <span aria-hidden="true">🧪</span> Zero-login · stateless · free forever
    </span>
    <h1 class="mt-7 text-4xl font-bold leading-[1.1] tracking-tight text-slate-900 sm:text-5xl md:text-6xl dark:text-slate-50">
      The Planning Playground for
      <span class="bg-gradient-to-r from-indigo-600 to-violet-500 bg-clip-text text-transparent">High-Velocity Product Teams.</span>
    </h1>
    <p class="mx-auto mt-6 max-w-2xl text-base leading-relaxed text-slate-600 sm:text-lg dark:text-slate-400">
      Vibs is a zero-login, stateless sandbox built to model Monte Carlo delivery forecasts and
      decompose sprawling user epics into code-ready requirements — without cluttering your
      production Jira or Linear boards.
    </p>
    <div class="mt-9 flex flex-col items-center justify-center gap-3 sm:flex-row">
      <button
        id="landing-open-sandbox"
        type="button"
        class="w-full rounded-xl bg-indigo-600 px-7 py-3.5 text-sm font-bold text-white shadow-lg shadow-indigo-600/25 transition hover:-translate-y-0.5 hover:bg-indigo-500 active:translate-y-0 sm:w-auto"
      >
        Open Free Sandbox
      </button>
      <button
        id="landing-demo"
        type="button"
        class="w-full rounded-xl border border-slate-300 bg-white px-7 py-3.5 text-sm font-semibold text-slate-700 transition hover:-translate-y-0.5 hover:border-indigo-300 hover:bg-slate-50 active:translate-y-0 sm:w-auto dark:border-slate-700 dark:bg-slate-900 dark:text-slate-200 dark:hover:border-indigo-700 dark:hover:bg-slate-800"
      >
        Launch Interactive Demo <span class="font-normal opacity-70">(With Sample Data)</span>
      </button>
    </div>
    <p class="mt-4 text-xs text-slate-400 dark:text-slate-500">
      No account. No install. Your data never leaves your browser.
    </p>
  </header>

  <!-- Feature showcase -->
  <section aria-label="What makes vibs.io different" class="mx-auto max-w-6xl px-6 pb-4 sm:px-8">
    <div class="grid gap-6 md:grid-cols-3">
      {
        features.map((f) => (
          <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900">
            <div class="flex h-11 w-11 items-center justify-center rounded-xl bg-indigo-50 text-xl dark:bg-indigo-950" aria-hidden="true">
              {f.icon}
            </div>
            <h2 class="mt-4 text-lg font-semibold text-slate-900 dark:text-slate-100">{f.title}</h2>
            <p class="mt-2 text-sm leading-relaxed text-slate-600 dark:text-slate-400">{f.body}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Decorative Monte Carlo illustration -->
  <section class="mx-auto max-w-6xl px-6 pb-20 pt-8 sm:px-8">
    <div class="rounded-3xl border border-slate-200 bg-gradient-to-b from-slate-50 to-white p-6 shadow-sm sm:p-10 dark:border-slate-800 dark:from-slate-900 dark:to-slate-950">
      <p class="mb-1 text-center text-xs font-semibold uppercase tracking-wide text-indigo-600 dark:text-indigo-400">
        Probability, not promises
      </p>
      <p class="mx-auto mb-6 max-w-xl text-center text-sm text-slate-500 dark:text-slate-400">
        Every forecast brackets your real velocity history into optimistic, expected, and
        pessimistic delivery trajectories — so dates carry confidence, not wishful thinking.
      </p>
      <svg viewBox="0 0 800 300" class="w-full" fill="none" role="img" aria-label="Illustration of Monte Carlo burnup trajectories">
        <!-- axes -->
        <line x1="60" y1="250" x2="760" y2="250" stroke="currentColor" class="text-slate-300 dark:text-slate-700" stroke-width="1.5" />
        <line x1="60" y1="40" x2="60" y2="250" stroke="currentColor" class="text-slate-300 dark:text-slate-700" stroke-width="1.5" />
        <!-- total scope line -->
        <line x1="60" y1="60" x2="760" y2="60" stroke="#a855f7" stroke-width="1.5" stroke-dasharray="6 5" opacity="0.7" />
        <!-- history -->
        <polyline points="60,250 170,210 280,196 390,150" stroke="#6366f1" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" />
        <circle cx="390" cy="150" r="5" fill="#6366f1" />
        <!-- three projection trajectories -->
        <line x1="390" y1="150" x2="620" y2="60" stroke="#10b981" stroke-width="2.5" stroke-linecap="round" />
        <line x1="390" y1="150" x2="700" y2="60" stroke="#3b82f6" stroke-width="2.5" stroke-linecap="round" />
        <line x1="390" y1="150" x2="760" y2="72" stroke="#ef4444" stroke-width="2.5" stroke-linecap="round" />
        <circle cx="620" cy="60" r="4.5" fill="#10b981" />
        <circle cx="700" cy="60" r="4.5" fill="#3b82f6" />
        <circle cx="760" cy="72" r="4.5" fill="#ef4444" />
      </svg>
      <div class="mt-4 flex flex-wrap justify-center gap-x-6 gap-y-1 text-[11px] font-medium">
        <span class="flex items-center gap-1.5 text-slate-500 dark:text-slate-400"><span class="h-2 w-2 rounded-full bg-emerald-500"></span> Optimistic</span>
        <span class="flex items-center gap-1.5 text-slate-500 dark:text-slate-400"><span class="h-2 w-2 rounded-full bg-blue-500"></span> Expected</span>
        <span class="flex items-center gap-1.5 text-slate-500 dark:text-slate-400"><span class="h-2 w-2 rounded-full bg-rose-500"></span> Pessimistic</span>
      </div>
    </div>
  </section>

  <footer class="border-t border-slate-200 py-6 dark:border-slate-800">
    <p class="mx-auto max-w-6xl px-6 text-center text-xs text-slate-400 sm:px-8 dark:text-slate-500">
      vibs.io — your plan lives in the URL. No account required.
      · <a href="/privacy" class="hover:underline">Privacy</a>
      · <a href="/terms" class="hover:underline">Terms</a>
    </p>
  </footer>
</div>
